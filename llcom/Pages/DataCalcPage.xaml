<Page
    x:Class="llcom.Pages.DataCalcPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DataCalcPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button
                    Name="SelectFileButton"
                    MinWidth="80"
                    Margin="0,0,6,0"
                    Click="SelectFileButton_Click"
                    Content="{DynamicResource DataCalcSelectFile}" />
                <Button
                    Name="SendFileDataButton"
                    MinWidth="80"
                    Margin="0,0,6,0"
                    Click="SendFileDataButton_Click"
                    Content="{DynamicResource DataCalcSendFile}"
                    IsEnabled="False" />
            </StackPanel>
            <TextBox
                Name="FilePathTextBox"
                Grid.Column="1"
                Margin="0,0,6,0"
                IsReadOnly="True"
                Text="{DynamicResource DataCalcNoFileSelected}" />
            <TextBlock
                Name="FileLengthTextBlock"
                Grid.Column="2"
                MinWidth="110"
                VerticalAlignment="Center"
                Text="0 bytes" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,4">
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="{DynamicResource DataCalcManualInput}" />
                <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                    <CheckBox
                        Name="HexInputCheckBox"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Checked="ManualDataChanged"
                        Content="{DynamicResource DataCalcHexInput}"
                        Unchecked="ManualDataChanged" />
                    <Button
                        MinWidth="70"
                        Click="CalculateManualButton_Click"
                        Content="{DynamicResource DataCalcCalculate}" />
                </StackPanel>
            </DockPanel>
            <TextBox
                Name="ManualDataTextBox"
                Grid.Row="1"
                Grid.Column="0"
                AcceptsReturn="True"
                FontFamily="Consolas"
                TextChanged="ManualDataChanged"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />

            <DockPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,4">
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="{DynamicResource DataCalcResult}" />
            </DockPanel>
            <TextBox
                Name="ResultTextBox"
                Grid.Row="1"
                Grid.Column="2"
                AcceptsReturn="True"
                FontFamily="Consolas"
                IsReadOnly="True"
                TextWrapping="NoWrap"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Page>
