<Window
    x:Class="llcom.DataCalcWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    Title="{DynamicResource DataCalcToolTab}"
    Width="1400"
    Height="620"
    MinWidth="1000"
    MinHeight="480"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0"
    Closing="Window_Closing"
    WindowStartupLocation="CenterOwner">
    <Window.Style>
        <Style BasedOn="{StaticResource {x:Type Window}}" TargetType="Window" />
    </Window.Style>
    <Frame NavigationUIVisibility="Hidden" Source="/Pages/DataCalcPage.xaml" />
</Window>
