<Window
    x:Class="llcom_plus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:local="clr-namespace:llcom_plus"
    xmlns:local_page="clr-namespace:llcom_plus.Pages"
    xmlns:local_tool="clr-namespace:llcom_plus.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{DynamicResource AppTitle}"
    Width="1440"
    Height="820"
    MinWidth="1120"
    MinHeight="680"
    Icon="pack://application:,,,/Resources/Assets/AppIcon.ico"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0"
    Activated="Window_Activated"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded"
    SourceInitialized="Window_SourceInitialized"
    mc:Ignorable="d">
    <Window.Style>
        <Style BasedOn="{StaticResource AppGlassWindowStyle}" TargetType="Window" />
    </Window.Style>
    <Window.Resources>
        <RoutedUICommand x:Key="SendUartData" Text="SendUartData" />
        <local_page:boolVisibe x:Key="boolVisibeConverter" />
        <local_page:boolNotVisibe x:Key="boolNotVisibeConverter" />
        <local_page:rsTooltip x:Key="rsToolTipConverter" />
        <local_page:rsOpacity x:Key="rsOpacityConverter" />
        <local_page:boolOpacity x:Key="boolOpacityConverter" />
        <Style x:Key="GlassPanelStyle" BasedOn="{StaticResource AppGlassCardStyle}" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style x:Key="GlassPanelTightStyle" BasedOn="{StaticResource GlassPanelStyle}" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="13" />
        </Style>
        <Style x:Key="FloatingGlassShadowStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppGlassShadowCasterBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="30"
                        Direction="270"
                        Opacity="0.72"
                        RenderingBias="Quality"
                        ShadowDepth="12"
                        Color="{DynamicResource AppShadowColor}" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FloatingGlassHighlightStyle" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassHighlightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Panel.ZIndex" Value="20" />
        </Style>
        <Style x:Key="GlassButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="GlassTextBoxStyle" BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource AppGlassInputBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
        <Style x:Key="ComposerShadowStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppGlassShadowCasterBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="34"
                        Direction="270"
                        Opacity="0.34"
                        RenderingBias="Quality"
                        ShadowDepth="11"
                        Color="{DynamicResource AppShadowColor}" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerTextBoxStyle" BasedOn="{StaticResource GlassTextBoxStyle}" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerToolButtonStyle" BasedOn="{StaticResource GlassButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="{DynamicResource AppFloatingGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppFloatingGlassControlBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassTextBrush}" />
        </Style>
        <Style x:Key="FloatingToolbarPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppFloatingGlassBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppFloatingGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="FloatingToolbarShadowStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppGlassShadowCasterBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="30"
                        Direction="270"
                        Opacity="0.3"
                        RenderingBias="Quality"
                        ShadowDepth="10"
                        Color="{DynamicResource AppShadowColor}" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FloatingContentPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppFloatingContentBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppFloatingContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="FloatingContentShadowStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppGlassShadowCasterBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="40"
                        Direction="270"
                        Opacity="0.32"
                        RenderingBias="Quality"
                        ShadowDepth="14"
                        Color="{DynamicResource AppShadowColor}" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerSendButtonStyle" BasedOn="{StaticResource AppAccentButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
        </Style>
        <Style x:Key="GlassTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,18"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0">
                                <TabPanel
                                    IsItemsHost="True"
                                    KeyboardNavigation.TabIndex="1"
                                    Panel.ZIndex="1" />
                            </Border>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter
                                    x:Name="PART_SelectedContentHost"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Background" Value="{DynamicResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassTextBrush}" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border
                            x:Name="Chrome"
                            MinHeight="31"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppGlassControlHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppGlassFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppPopupBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolListBoxStyle" BasedOn="{StaticResource {x:Type ListBox}}" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="ToolListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassTextBrush}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border
                            x:Name="Chrome"
                            MinHeight="38"
                            Padding="{TemplateBinding Padding}"
                            Background="{DynamicResource AppGlassControlBackground}"
                            BorderBrush="{DynamicResource AppGlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="9">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppGlassControlHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppGlassFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppPopupBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatusPillStyle" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{DynamicResource AppFloatingGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppFloatingGlassControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
        <Style x:Key="StatusToggleButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{DynamicResource AppFloatingGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppFloatingGlassControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassMutedBrush}" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>
        <Style x:Key="StatusValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassTextBrush}" />
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding
            Key="Return"
            Command="{StaticResource SendUartData}"
            Gesture="Ctrl+Return" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{StaticResource SendUartData}" Executed="SendUartData_Executed" />
    </Window.CommandBindings>
    <Grid
        Name="MainGrid"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        ClipToBounds="True"
        IsEnabled="False"
        SizeChanged="MainGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MainLogBaseColumn" Width="430" MinWidth="430" />
            <ColumnDefinition x:Name="MainLogFlexibleColumn" Width="*" />
            <ColumnDefinition x:Name="RightToolsToggleColumn" Width="Auto" />
            <ColumnDefinition x:Name="RightToolsColumn" Width="760" MinWidth="650" />
        </Grid.ColumnDefinitions>

        <!--  A static, cached wallpaper blur gives every translucent card a frosted
              backdrop without applying expensive effects to the live log controls.  -->
        <Grid
            Grid.RowSpan="3"
            Grid.ColumnSpan="4"
            ClipToBounds="True"
            IsHitTestVisible="False">
            <Image
                Width="1920"
                Height="1920"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CacheMode="BitmapCache"
                Opacity="{DynamicResource AppBackdropImageOpacity}"
                RenderOptions.BitmapScalingMode="HighQuality"
                Stretch="Uniform">
                <Image.Source>
                    <BitmapImage
                        CacheOption="OnLoad"
                        DecodePixelWidth="1920"
                        UriSource="pack://application:,,,/Resources/Assets/AppBackground.png" />
                </Image.Source>
                <Image.Effect>
                    <BlurEffect Radius="8" RenderingBias="Performance" />
                </Image.Effect>
            </Image>
            <Border Background="{DynamicResource AppAmbientTopBrush}" />
            <Border Background="{DynamicResource AppAmbientBottomBrush}" />
            <Border Background="{DynamicResource AppWindowOverlayBrush}" />
        </Grid>

        <!--  收发数据显示  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="10,10,6,6"
            CornerRadius="18"
            Style="{StaticResource FloatingGlassShadowStyle}" />
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="10,10,6,6"
            Padding="6"
            Style="{StaticResource GlassPanelStyle}" Grid.ColumnSpan="2">
            <Frame
                Name="dataShowFrame"
                Background="Transparent"
                BorderBrush="#00000000"
                BorderThickness="0.5"
                FocusVisualStyle="{x:Null}"
                GotFocus="uartDataFlowDocument_GotFocus"
                LostFocus="uartDataFlowDocument_LostFocus"
                NavigationUIVisibility="Hidden"
                PreviewKeyDown="uartDataFlowDocument_PreviewKeyDown"
                PreviewTextInput="uartDataFlowDocument_PreviewTextInput" />
        </Border>
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="10,10,6,6"
            CornerRadius="18"
            Style="{StaticResource FloatingGlassHighlightStyle}" />

        <!--  发送数据区  -->
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="10,4,6,8"
            CornerRadius="20"
            Style="{StaticResource ComposerShadowStyle}" />
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="10,4,6,8"
            Padding="8,7"
            Background="{DynamicResource AppFloatingGlassBackground}"
            BorderBrush="{DynamicResource AppFloatingGlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox
                Name="toSendDataTextBox"
                MinHeight="68"
                Style="{StaticResource ComposerTextBoxStyle}"
                VerticalContentAlignment="Top"
                AcceptsReturn="True"
                FontFamily="Consolas"
                PreviewKeyDown="ToSendDataTextBox_PreviewKeyDown"
                Text="{Binding dataToSend}"
                TextChanged="ToSendDataTextBox_TextChanged"
                TextWrapping="Wrap"
                LostFocus="ToSendDataTextBox_LostFocus"
                VerticalScrollBarVisibility="Auto" />
                <Popup
                Name="sendSuggestPopup"
                AllowsTransparency="True"
                Placement="Top"
                PlacementTarget="{Binding ElementName=toSendDataTextBox}"
                StaysOpen="False"
                VerticalOffset="-4">
                    <Border
                    Padding="3"
                    Background="{DynamicResource AppPopupBackground}"
                    BorderBrush="{DynamicResource AppGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                        <ListBox
                        Name="sendSuggestListBox"
                        MinHeight="26"
                        MaxHeight="180"
                        Width="{Binding ElementName=toSendDataTextBox, Path=ActualWidth}"
                        FontFamily="Consolas"
                        HorizontalContentAlignment="Stretch"
                        MouseDoubleClick="SendSuggestListBox_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Margin="2,0,8,0"
                                            VerticalAlignment="Center"
                                            Text="{Binding SendText}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="8,0,4,0"
                                            VerticalAlignment="Center"
                                            Opacity="0.72"
                                            Text="{Binding ButtonText}"
                                            TextAlignment="Right"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
                <Grid Grid.Row="1" Margin="2,2,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                    Name="clearLogButton"
                    Style="{StaticResource ComposerToolButtonStyle}"
                    Click="ClearLogButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Margin="0,0,6,0" VerticalAlignment="Center" Icon="Eraser" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource ClearLog}" />
                        </StackPanel>
                    </Button>
                    <Button
                    Name="FlowControlButton"
                    Grid.Column="1"
                    Style="{StaticResource ComposerToolButtonStyle}"
                    Click="FlowControlButton_Click"
                    ToolTip="{DynamicResource FlowControlButtonTip}">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Margin="0,0,6,0" VerticalAlignment="Center" Icon="Exchange" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource FlowControlButton}" />
                        </StackPanel>
                    </Button>
                    <Button
                    Name="MoreSettingButton"
                    Grid.Column="2"
                    Style="{StaticResource ComposerToolButtonStyle}"
                    Click="MoreSettingButton_Click"
                    ToolTip="{DynamicResource MoreSettingsTip}">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Margin="0,0,6,0" VerticalAlignment="Center" Icon="Cog" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource MoreSettings}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Name="SendAndLogOptionsButton"
                        Grid.Column="4"
                        Width="36"
                        Height="32"
                        Padding="0"
                        Style="{StaticResource ComposerToolButtonStyle}"
                        Click="SendAndLogOptionsButton_Click"
                        ToolTip="{DynamicResource SendAndLogOptionsTip}">
                        <fa:FontAwesome FontSize="14" Icon="Sliders" />
                    </Button>
                    <Border
                        Grid.Column="5"
                        Width="1"
                        Height="22"
                        Margin="5,0,10,0"
                        VerticalAlignment="Center"
                        Background="{DynamicResource AppGlassBorderBrush}" />
                    <Button
                    Name="sendDataButton"
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Style="{StaticResource ComposerSendButtonStyle}"
                    Command="{StaticResource SendUartData}"
                    ToolTip="{DynamicResource SendDataButtonTip}"
                    Content="{DynamicResource SendDataButton}" />
                </Grid>
            </Grid>
        </Border>
        <!--  底部状态栏  -->
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="4"
            Margin="10,0,10,10"
            Style="{StaticResource FloatingToolbarShadowStyle}" />
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="4"
            Margin="10,0,10,10"
            Padding="4"
            Style="{StaticResource FloatingToolbarPanelStyle}">
            <WrapPanel VerticalAlignment="Center">
                <Button
                Name="refreshPortButton"
                MinHeight="32"
                Margin="0,0,8,0"
                Style="{StaticResource GlassButtonStyle}"
                Click="RefreshPortButton_Click"
                Content="{DynamicResource RefreshPortButton}"
                IsEnabled="{Binding ElementName=serialPortsListComboBox, Path=IsEnabled}" />
                <StackPanel
                Name="serialSplitSendTargetPanel"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                    <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource SplitSendTarget}" />
                    <ComboBox
                    Name="serialSplitSendTargetComboBox"
                    MinWidth="88"
                    MaxWidth="240"
                    MinHeight="32"
                    SelectionChanged="SerialSplitSendTargetComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Text}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap"
                                    ToolTip="{Binding Text}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                    <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource ShowPorts}" />
                    <ComboBox
                    Name="serialPortsListComboBox"
                    MinWidth="96"
                    MaxWidth="280"
                    MinHeight="32"
                    SelectionChanged="SerialPortsListComboBox_SelectionChanged" />
                </StackPanel>
                <StackPanel
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                    <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource ShowBaudRate}" />
                    <ComboBox
