            Margin="10,12,12,8"
            CornerRadius="18"
            Style="{StaticResource FloatingGlassHighlightStyle}" />

        <Grid
            x:Name="RightTopActions"
            Grid.Column="3"
            Margin="0,18,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top">
            <Border Style="{StaticResource FloatingGlassShadowStyle}" CornerRadius="15" />
            <Border
                Padding="4"
                Background="{DynamicResource AppGlassPanelBackground}"
                BorderBrush="{DynamicResource AppGlassHighlightBrush}"
                BorderThickness="1"
                CornerRadius="15">
                <StackPanel Orientation="Horizontal">
                    <Button
                        Name="ThemeToggleMenuItem"
                        Width="36"
                        Height="36"
                        Margin="0,0,4,0"
                        Padding="0"
                        Click="ThemeToggleMenuItem_Click"
                        ToolTip="{DynamicResource DarkMode}">
                        <fa:FontAwesome
                            Name="ThemeToggleIcon"
                            Width="16"
                            Height="16"
                            FontSize="16"
                            Foreground="{DynamicResource AppAccentBrush}"
                            Icon="Adjust" />
                    </Button>
                    <Button
                        Name="LanguageMenuButton"
                        Width="36"
                        Height="36"
                        Padding="0"
                        Click="LanguageMenuButton_Click"
                        ToolTip="{DynamicResource ChangeLanguage}">
                        <fa:FontAwesome
                            Width="16"
                            Height="16"
                            FontSize="16"
                            Foreground="{DynamicResource AppInfoBrush}"
                            Icon="Globe" />
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom" VerticalOffset="6">
                                <MenuItem
                                    Click="MenuItem_Click"
                                    Header="简体中文"
                                    Tag="zh-CN" />
                                <MenuItem
                                    Click="MenuItem_Click"
                                    Header="English"
                                    Tag="en-US" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource FloatingGlassHighlightStyle}" CornerRadius="15" />
        </Grid>
    </Grid>
</Window>
