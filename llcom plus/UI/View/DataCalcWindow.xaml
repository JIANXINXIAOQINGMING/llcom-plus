<Window
    x:Class="llcom_plus.DataCalcWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    Title="{DynamicResource DataCalcResult}"
    Width="900"
    Height="360"
    MinWidth="720"
    MinHeight="300"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0"
    WindowStartupLocation="CenterOwner">
    <Window.Style>
        <Style BasedOn="{StaticResource AppGlassWindowStyle}" TargetType="Window" />
    </Window.Style>
    <ScrollViewer
        Margin="12"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,3,10,3" VerticalAlignment="Center" Text="{DynamicResource DataCalcResultLength}" />
            <TextBox Name="LengthResultTextBox" Grid.Row="0" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />

            <TextBlock Grid.Row="1" Margin="0,3,10,3" VerticalAlignment="Center" Text="MD5" />
            <TextBox Name="Md5ResultTextBox" Grid.Row="1" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />

            <TextBlock Grid.Row="2" Margin="0,3,10,3" VerticalAlignment="Center" Text="SHA1" />
            <TextBox Name="Sha1ResultTextBox" Grid.Row="2" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />

            <TextBlock Grid.Row="3" Margin="0,3,10,3" VerticalAlignment="Center" Text="SHA256" />
            <TextBox Name="Sha256ResultTextBox" Grid.Row="3" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />

            <TextBlock Grid.Row="4" Margin="0,3,10,3" VerticalAlignment="Center" Text="SHA512" />
            <TextBox Name="Sha512ResultTextBox" Grid.Row="4" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />

            <TextBlock Grid.Row="5" Margin="0,3,10,3" VerticalAlignment="Center" Text="CRC16(Modbus)" />
            <TextBox Name="Crc16ResultTextBox" Grid.Row="5" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />

            <TextBlock Grid.Row="6" Margin="0,3,10,3" VerticalAlignment="Center" Text="CRC32" />
            <TextBox Name="Crc32ResultTextBox" Grid.Row="6" Grid.Column="1" Margin="0,2" FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="NoWrap" />
        </Grid>
    </ScrollViewer>
</Window>
