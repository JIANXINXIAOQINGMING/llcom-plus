<Page
    x:Class="llcom_plus.Pages.MultiPortPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    Title="MultiPortPage"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">
    <Page.Resources>
        <Style x:Key="SplitLogOptionCheckBoxStyle" BasedOn="{StaticResource {x:Type CheckBox}}" TargetType="{x:Type CheckBox}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="SplitLogOptionButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SplitLogOptionsToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppGlassControlHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppGlassFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid x:Name="RootGrid" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel x:Name="ToolbarPanel" Margin="0,0,0,8">
            <Button
                MinWidth="88"
                Margin="0,0,8,0"
                Click="RefreshPortsButton_Click"
                Content="{DynamicResource MultiPortRefresh}" />
            <Button
                MinWidth="88"
                Margin="0,0,8,0"
                Click="CloseAllButton_Click"
                Content="{DynamicResource MultiPortCloseAll}" />
            <TextBlock
                x:Name="StatusTextBlock"
                VerticalAlignment="Center"
                Foreground="{DynamicResource AppGlassMutedBrush}" />
        </DockPanel>

        <Grid
            x:Name="SlotsGrid"
            Grid.Row="1"
            ClipToBounds="True" />
        <ToggleButton
            x:Name="ExternalOptionsButton"
            Grid.RowSpan="2"
            Margin="0,0,10,10"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Panel.ZIndex="30"
            Style="{StaticResource SplitLogOptionsToggleButtonStyle}"
            ToolTip="{DynamicResource SendAndLogOptionsTip}"
            Visibility="Collapsed">
            <fa:FontAwesome Icon="Sliders" FontSize="14" />
        </ToggleButton>
        <Popup
            x:Name="ExternalOptionsPopup"
            AllowsTransparency="True"
            HorizontalOffset="-6"
            IsOpen="{Binding IsChecked, ElementName=ExternalOptionsButton, Mode=TwoWay}"
            Placement="Left"
            PlacementTarget="{Binding ElementName=ExternalOptionsButton}"
            StaysOpen="True">
            <Border
                Width="410"
                Padding="12"
                Background="{DynamicResource AppPopupBackground}"
                BorderBrush="{DynamicResource AppGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="13">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.34"
                        ShadowDepth="8"
                        Color="{DynamicResource AppShadowColor}" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock
                        x:Name="ExternalOptionsTitle"
                        Margin="4,0,4,8"
                        FontWeight="SemiBold"
                        Text="{DynamicResource SendAndLogOptions}" />
                    <WrapPanel>
                        <CheckBox
                            x:Name="ExternalRTSCheckBox"
                            Checked="ExternalControlCheckBox_Changed"
                            Content="RTS"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            Unchecked="ExternalControlCheckBox_Changed" />
                        <CheckBox
                            x:Name="ExternalDTRCheckBox"
                            Checked="ExternalControlCheckBox_Changed"
                            Content="DTR"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            Unchecked="ExternalControlCheckBox_Changed" />
                        <CheckBox
                            x:Name="ExternalHexCheckBox"
                            Checked="ExternalControlCheckBox_Changed"
                            Content="{DynamicResource HexSendMode}"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            Unchecked="ExternalControlCheckBox_Changed" />
                        <CheckBox
                            x:Name="ExtraEnterCheckBox"
                            Content="{DynamicResource AddExtraEnter}"
                            IsChecked="{Binding extraEnter}"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource AddExtraEnterTip}" />
                        <CheckBox
                            x:Name="EnterSendCheckBox"
                            Content="{DynamicResource EnterSendMode}"
                            IsChecked="{Binding enterSend}"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource EnterSendModeTip}" />
                        <CheckBox
                            x:Name="EnableSymbolCheckBox"
                            Content="{DynamicResource ShowSymbol}"
                            IsChecked="{Binding EnableSymbol}"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource ShowSymbolTooltip}" />
                        <CheckBox
                            x:Name="DisableLogCheckBox"
                            Content="{DynamicResource DisableLog}"
                            IsChecked="{Binding DisableLog}"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}" />
                        <CheckBox
                            x:Name="SessionLogCheckBox"
                            Checked="SessionLogCheckBox_Changed"
                            Content="{DynamicResource SessionLog}"
                            IsChecked="{Binding sessionLogEnabled}"
                            Style="{StaticResource SplitLogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource SessionLogTip}"
                            Unchecked="SessionLogCheckBox_Changed" />
                    </WrapPanel>
                    <Border
                        Height="1"
                        Margin="4,8,4,8"
                        Background="{DynamicResource AppGlassBorderBrush}" />
                    <WrapPanel>
                        <Button
                            x:Name="ExternalLockLogsButton"
                            Click="ExternalLockLogsButton_Click"
                            Style="{StaticResource SplitLogOptionButtonStyle}"
                            ToolTip="{DynamicResource LockLogButton}">
                            <StackPanel Orientation="Horizontal">
                                <fa:FontAwesome
                                    x:Name="ExternalLockLogsIcon"
                                    Width="16"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Icon="Lock" />
                                <TextBlock
                                    x:Name="ExternalLockLogsText"
                                    VerticalAlignment="Center"
                                    Text="{DynamicResource LockLogAction}" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="ExternalSaveLogsButton"
                            Click="ExternalSaveLogsButton_Click"
                            Style="{StaticResource SplitLogOptionButtonStyle}"
                            ToolTip="{DynamicResource SaveLogButton}">
                            <StackPanel Orientation="Horizontal">
                                <fa:FontAwesome
                                    Width="16"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Icon="Save" />
                                <TextBlock VerticalAlignment="Center" Text="{DynamicResource SaveLogAction}" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="SessionLogFolderButton"
                            Click="SessionLogFolderButton_Click"
                            Content="{DynamicResource SessionLogFolder}"
                            Style="{StaticResource SplitLogOptionButtonStyle}"
                            ToolTip="{DynamicResource SessionLogFolderTip}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>
