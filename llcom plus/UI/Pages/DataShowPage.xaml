<Page
    x:Class="llcom_plus.Pages.DataShowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:local="clr-namespace:llcom_plus.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DataShowPage"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <local:boolVisibe x:Key="boolVisibeConverter" />
        <local:boolNotVisibe x:Key="boolNotVisibeConverter" />
        <Style x:Key="DataShowStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <RichTextBox
                            Name="ItemGrid"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas,Microsoft YaHei,微软雅黑"
                            FontSize="12"
                            IsReadOnly="True">
                            <FlowDocument>
                                <Paragraph Margin="0">
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding TimeText}" />
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding ArrowText}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding DataTextColor}"
                                        Text="{Binding DataText}" />
                                    <Run
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AppGlassTextBrush}"
                                        Text="{Binding RawTitle}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding RawTextColor}"
                                        Text="{Binding RawText}" />
                                    <Run Foreground="{Binding HexTextColor}" Text="{Binding HexText}" />
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="ItemGrid" Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="Selector.IsSelected" Value="true">
                                <Setter TargetName="ItemGrid" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LogOptionCheckBoxStyle" BasedOn="{StaticResource {x:Type CheckBox}}" TargetType="{x:Type CheckBox}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="LogOptionButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="LogOptionsToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource AppGlassTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppGlassControlHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppGlassFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid x:Name="mainGrid" Background="Transparent">
        <TextBox
            Name="MainTextBox"
            VerticalContentAlignment="Top"
            Background="Transparent"
            BorderThickness="0"
            FontFamily="Consolas,Microsoft YaHei,微软雅黑"
            FontSize="15"
            Foreground="{DynamicResource AppDataReceivedBrush}"
            IsReadOnly="True"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            TextWrapping="Wrap" />
        <ScrollViewer Name="MainListScrollViewer" VerticalScrollBarVisibility="Auto">
            <ItemsControl
                Name="MainList"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                VirtualizingStackPanel.CacheLength="2,2"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RichTextBox
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas,Microsoft YaHei,微软雅黑"
                            FontSize="12"
                            IsReadOnly="True">
                            <FlowDocument>
                                <Paragraph Margin="0">
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding TimeText}" />
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding ArrowText}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding DataTextColor}"
                                        Text="{Binding DataText}" />
                                    <Run
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AppGlassTextBrush}"
                                        Text="{Binding RawTitle}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding RawTextColor}"
                                        Text="{Binding RawText}" />
                                    <Run Foreground="{Binding HexTextColor}" Text="{Binding HexText}" />
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <ToggleButton
            Name="LogOptionsButton"
            Margin="0,0,18,3"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Panel.ZIndex="30"
            Style="{StaticResource LogOptionsToggleButtonStyle}"
            ToolTip="{DynamicResource SendAndLogOptionsTip}"
            Visibility="Collapsed">
            <fa:FontAwesome Icon="Sliders" FontSize="14" />
        </ToggleButton>
        <Popup
            Name="LogOptionsPopup"
            AllowsTransparency="True"
            HorizontalOffset="-6"
            IsOpen="{Binding IsChecked, ElementName=LogOptionsButton, Mode=TwoWay}"
            Placement="Left"
            PlacementTarget="{Binding ElementName=LogOptionsButton}"
            StaysOpen="True">
            <Border
                Width="410"
                Padding="12"
                Background="{DynamicResource AppPopupBackground}"
                BorderBrush="{DynamicResource AppGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="13">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.34"
                        ShadowDepth="8"
                        Color="{DynamicResource AppShadowColor}" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock
                        Margin="4,0,4,8"
                        FontWeight="SemiBold"
                        Text="{DynamicResource SendAndLogOptions}" />
                    <WrapPanel>
                        <CheckBox
                            Name="RTSCheckBox"
                            Click="ControlLineCheckBox_Click"
                            Content="RTS"
                            IsChecked="{Binding Rts}"
                            Style="{StaticResource LogOptionCheckBoxStyle}" />
                        <CheckBox
                            Name="DTRCheckBox"
                            Click="ControlLineCheckBox_Click"
                            Content="DTR"
                            IsChecked="{Binding Dtr}"
                            Style="{StaticResource LogOptionCheckBoxStyle}" />
                        <CheckBox
                            Name="HexSendCheckBox"
                            Content="{DynamicResource HexSendMode}"
                            IsChecked="{Binding hexSend}"
                            Style="{StaticResource LogOptionCheckBoxStyle}" />
                        <CheckBox
                            Name="ExtraEnterCheckBox"
                            Content="{DynamicResource AddExtraEnter}"
                            IsChecked="{Binding extraEnter}"
                            Style="{StaticResource LogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource AddExtraEnterTip}" />
                        <CheckBox
                            Name="EnterSendCheckBox"
                            Content="{DynamicResource EnterSendMode}"
                            IsChecked="{Binding enterSend}"
                            Style="{StaticResource LogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource EnterSendModeTip}" />
                        <CheckBox
                            Name="EnableSymbolCheckBox"
                            Content="{DynamicResource ShowSymbol}"
                            IsChecked="{Binding EnableSymbol}"
                            Style="{StaticResource LogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource ShowSymbolTooltip}" />
                        <CheckBox
                            Name="DisableLogCheckBox"
                            Content="{DynamicResource DisableLog}"
                            IsChecked="{Binding DisableLog}"
                            Style="{StaticResource LogOptionCheckBoxStyle}" />
                        <CheckBox
                            Name="SessionLogCheckBox"
                            Content="{DynamicResource SessionLog}"
                            IsChecked="{Binding sessionLogEnabled}"
                            Style="{StaticResource LogOptionCheckBoxStyle}"
                            ToolTip="{DynamicResource SessionLogTip}" />
                    </WrapPanel>
                    <Border
                        Height="1"
                        Margin="4,8,4,8"
                        Background="{DynamicResource AppGlassBorderBrush}" />
                    <WrapPanel>
                        <Button
                            Name="LockLogButton"
                            Click="LockLogButton_Click"
                            Style="{StaticResource LogOptionButtonStyle}"
                            ToolTip="{DynamicResource LockLogButton}">
                            <StackPanel Orientation="Horizontal">
                                <fa:FontAwesome
                                    Name="LockIcon"
                                    Width="16"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Icon="Lock"
                                    Visibility="{Binding LockLog, Converter={StaticResource boolNotVisibeConverter}}" />
                                <fa:FontAwesome
                                    Name="UnLockIcon"
                                    Width="16"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AppSuccessBrush}"
                                    Icon="Unlock"
                                    Visibility="{Binding LockLog, Converter={StaticResource boolVisibeConverter}}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{DynamicResource LockLogAction}"
                                    Visibility="{Binding LockLog, Converter={StaticResource boolNotVisibeConverter}}" />
                                <TextBlock
                                    Name="UnLockText"
                                    VerticalAlignment="Center"
                                    Text="{DynamicResource UnlockLogAction}"
                                    Visibility="{Binding LockLog, Converter={StaticResource boolVisibeConverter}}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Name="SaveLogButton"
                            Click="SaveLogButton_Click"
                            Style="{StaticResource LogOptionButtonStyle}"
                            ToolTip="{DynamicResource SaveLogButton}">
                            <StackPanel Orientation="Horizontal">
                                <fa:FontAwesome
                                    Width="16"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Icon="Save" />
                                <TextBlock VerticalAlignment="Center" Text="{DynamicResource SaveLogAction}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Name="SessionLogFolderButton"
                            Click="SessionLogFolderButton_Click"
                            Content="{DynamicResource SessionLogFolder}"
                            Style="{StaticResource LogOptionButtonStyle}"
                            ToolTip="{DynamicResource SessionLogFolderTip}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>
