<Page x:Class="llcom_plus.Pages.ConvertPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:llcom_plus.Pages"
      mc:Ignorable="d" 
      xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
      adonisExtensions:RippleExtension.FadeInDuration="0"
      adonisExtensions:RippleExtension.FadeOutDuration="0"
      d:DesignHeight="440" d:DesignWidth="400"
      Title="ConvertPage"
      Loaded="Page_Loaded">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="86"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MaxWidth="520"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Text="{DynamicResource EncodingToolsJobs}" />
            <ComboBox
                Name="ConvertNamesComBox"
                Grid.Column="1"
                MinWidth="180" />
        </Grid>
        <Border
            Grid.Row="1"
            Margin="0,0,0,6"
            BorderBrush="{DynamicResource AppGlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <ListBox
                Name="ConvertJobsListBox"
                Background="{DynamicResource AppGlassInputBackground}"
                ScrollViewer.CanContentScroll="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>
        </Border>
        <WrapPanel Grid.Row="2" Margin="0,0,0,6">
            <Button
                Name="ConvertButton"
                MinWidth="120"
                Margin="0,0,6,0"
                Click="ConvertButton_Click"
                Content="{DynamicResource EncodingToolsAddJob}" />
            <Button
                Name="ConvertClearButton"
                MinWidth="120"
                Click="ConvertClearButton_Click"
                Content="{DynamicResource EncodingToolsDeleteJob}" />
        </WrapPanel>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,0,4"
                HorizontalAlignment="Center"
                Text="{DynamicResource EncodingToolsRowData}" />
            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Margin="0,0,0,4"
                HorizontalAlignment="Center"
                Text="{DynamicResource EncodingToolsResultData}" />
            <TextBox
                Name="RawTextBox"
                Grid.Row="1"
                Grid.Column="0"
                AcceptsReturn="True"
                FontFamily="Consolas"
                TextChanged="RawTextBox_TextChanged"
                TextWrapping="Wrap"
                VerticalContentAlignment="Top"
                VerticalScrollBarVisibility="Auto" />
            <TextBox
                Name="ResultTextBox"
                Grid.Row="1"
                Grid.Column="2"
                FontFamily="Consolas"
                IsReadOnly="true"
                TextWrapping="Wrap"
                VerticalContentAlignment="Top"
                VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Page>
