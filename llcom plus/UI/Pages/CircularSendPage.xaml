<Page
    x:Class="llcom_plus.Pages.CircularSendPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="620"
    d:DesignWidth="920"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="CircularActionButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,3" />
        </Style>
    </Page.Resources>
    <Grid Margin="12" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- The selected tool in the navigation already supplies the page title. -->
        <WrapPanel
            x:Name="CircularToolbar"
            Margin="0,0,0,2"
            HorizontalAlignment="Right"
            ItemHeight="44">
            <Button
                Width="96"
                Height="36"
                Margin="0,0,8,0"
                Click="ClearSelectionButton_Click"
                Content="{DynamicResource CircularSendClearSelection}"
                Style="{StaticResource CircularActionButtonStyle}" />
            <Button
                Width="72"
                Height="36"
                Margin="0,0,8,0"
                Click="SelectAllButton_Click"
                Content="{DynamicResource CircularSendSelectAll}"
                Style="{StaticResource CircularActionButtonStyle}" />
            <Button
                Width="72"
                Height="36"
                Margin="0,0,8,0"
                Click="AddRowButton_Click"
                Content="{DynamicResource CircularSendAddRow}"
                Style="{StaticResource CircularActionButtonStyle}" />
            <Button
                Width="72"
                Height="36"
                Margin="0,0,8,0"
                Click="ClearButton_Click"
                Content="{DynamicResource CircularSendClear}"
                Style="{StaticResource CircularActionButtonStyle}" />
            <Button
                Width="136"
                Height="36"
                Click="ImportQuickSendButton_Click"
                Content="{DynamicResource CircularSendImportQuickSend}"
                Style="{StaticResource CircularActionButtonStyle}" />
        </WrapPanel>

        <TextBlock
            x:Name="StorageErrorTextBlock"
            Grid.Row="1"
            Margin="0,2,0,6"
            Foreground="IndianRed"
            TextWrapping="Wrap"
            Visibility="Collapsed" />

        <DataGrid
            x:Name="CommandDataGrid"
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            CanUserSortColumns="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Items}"
            SelectionMode="Single"
            SizeChanged="CommandDataGrid_SizeChanged"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Width="44" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendEnabled}" />
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Width="28" Binding="{Binding Index}" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendIndex}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="CommandColumn" Width="72" MinWidth="72" Binding="{Binding Command, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendCommand}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Width="42" Binding="{Binding Hex, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendHex}" />
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Width="68" Binding="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendDelay}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="52" Binding="{Binding Status}" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendStatus}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    MinWidth="42"
                                    Margin="0,0,4,0"
                                    Click="SendOneButton_Click"
                                    Content="{DynamicResource CircularSendSendOne}"
                                    Style="{StaticResource CircularActionButtonStyle}"
                                    Tag="{Binding}" />
                                <Button
                                    MinWidth="42"
                                    Click="RemoveRowButton_Click"
                                    Content="{DynamicResource CircularSendRemoveRow}"
                                    Style="{StaticResource CircularActionButtonStyle}"
                                    Tag="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel
            Grid.Row="3"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            ItemHeight="44">
            <StackPanel Margin="0,0,16,0" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{DynamicResource CircularSendTimes}" />
                <TextBox
                    x:Name="RunTimesTextBox"
                    Width="76"
                    Height="34"
                    Margin="6,0,0,0"
                    HorizontalContentAlignment="Center"
                    Text="1"
                    ToolTip="{DynamicResource CircularSendTimesTip}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,0" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{DynamicResource CircularSendDefaultDelay}" />
                <TextBox
                    x:Name="DefaultDelayTextBox"
                    Width="86"
                    Height="34"
                    Margin="6,0,0,0"
                    HorizontalContentAlignment="Center"
                    Text="1000"
                    ToolTip="{DynamicResource CircularSendDefaultDelayTip}" />
            </StackPanel>
                <TextBlock
                    x:Name="StatusTextBlock"
                    MinWidth="58"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource CircularSendIdle}" />
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="StartButton"
                        Width="104"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="StartButton_Click"
                        Style="{DynamicResource AppAccentButtonStyle}">
                        <TextBlock
                            Foreground="{DynamicResource AppAccentBrush}"
                            Text="{DynamicResource CircularSendStart}" />
                    </Button>
                    <Button
                        x:Name="StopButton"
                        Width="88"
                        Height="36"
                        Click="StopButton_Click"
                        Content="{DynamicResource CircularSendStop}"
                        IsEnabled="False"
                        Style="{StaticResource CircularActionButtonStyle}" />
                </StackPanel>
        </WrapPanel>
    </Grid>
</Page>
