<UserControl
    x:Class="llcom_plus.HttpToolWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    MinWidth="760"
    MinHeight="520"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0" Height="770">
    <Grid>
        <Grid.Background>
            <ImageBrush
                ImageSource="pack://application:,,,/Assets/AppBackground.png"
                Opacity="0.58"
                Stretch="UniformToFill" />
        </Grid.Background>
        <Border Background="#24FFF8EC" Margin="0,0,0,129" />
        <Grid Margin="16">
            <Grid.Resources>
                <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type TextBox}" />
                <Style BasedOn="{StaticResource {x:Type DataGrid}}" TargetType="{x:Type DataGrid}" />
                <Style TargetType="{x:Type TabControl}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabControl}">
                                <Grid KeyboardNavigation.TabNavigation="Local">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TabPanel
                                        Margin="0,0,0,10"
                                        IsItemsHost="True"
                                        KeyboardNavigation.TabIndex="1"
                                        Panel.ZIndex="1" />
                                    <ContentPresenter
                                        x:Name="PART_SelectedContentHost"
                                        Grid.Row="1"
                                        ContentSource="SelectedContent"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Background" Value="{StaticResource AppGlassControlBackground}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Foreground" Value="{StaticResource AppGlassTextBrush}" />
                    <Setter Property="Padding" Value="16,7" />
                    <Setter Property="Margin" Value="0,0,5,0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Border
                                    x:Name="Chrome"
                                    MinHeight="34"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                    <ContentPresenter
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppGlassControlHoverBackground}" />
                                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppGlassFocusBorderBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppPopupBackground}" />
                                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
                    <Setter Property="MinHeight" Value="30" />
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="320" MinHeight="280" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,12"
                Padding="10"
                Background="{StaticResource AppGlassPanelBackground}"
                BorderBrush="{StaticResource AppGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        x:Name="MethodComboBox"
                        Grid.Column="0"
                        Height="36"
                        Margin="0,0,8,0"
                        SelectedIndex="0"
                        VerticalContentAlignment="Center">
                        <ComboBoxItem Content="GET" />
                        <ComboBoxItem Content="POST" />
                        <ComboBoxItem Content="PUT" />
                        <ComboBoxItem Content="DELETE" />
                        <ComboBoxItem Content="PATCH" />
                        <ComboBoxItem Content="HEAD" />
                    </ComboBox>

                    <ComboBox
                        x:Name="UrlSchemeComboBox"
                        Grid.Column="1"
                        Height="36"
                        Margin="0,0,8,0"
                        SelectedIndex="1"
                        VerticalContentAlignment="Center">
                        <ComboBoxItem Content="http://" />
                        <ComboBoxItem Content="https://" />
                    </ComboBox>

                    <TextBox
                        x:Name="UrlTextBox"
                        Grid.Column="2"
                        Height="36"
                        Margin="0,0,8,0"
                        VerticalContentAlignment="Center"
                        FontSize="14"
                        Text="postman-echo.com/get" />

                    <Button
                        x:Name="SendButton"
                        Grid.Column="3"
                        Height="36"
                        Background="#0E9AA7"
                        Click="SendButton_Click"
                        Content="发送"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Margin="0,0,0,12">
                <TabItem Header="Headers" Margin="0,0,-5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="HeaderPresetComboBox"
                                Grid.Column="0"
                                Height="34"
                                Margin="-8,0,8,0"
                                SelectionChanged="HeaderPresetComboBox_SelectionChanged"
                                VerticalContentAlignment="Center" />

                            <TextBox
                                x:Name="HeaderDefaultValueTextBox"
                                Grid.Column="1"
                                Height="34"
                                Margin="0,0,8,0"
                                VerticalContentAlignment="Center"
                                FontFamily="Consolas"
                                Text="application/json" />

                            <Button
                                Grid.Column="2"
                                Height="34"
                                Click="AddHeaderPresetButton_Click"
                                Content="添加/更新" />
                        </Grid>

                        <TextBox
                            x:Name="RequestHeadersTextBox"
                            Grid.Row="1"
                            AcceptsReturn="True"
                            AcceptsTab="True"
                            FontFamily="Consolas"
                            FontSize="14"
                            HorizontalScrollBarVisibility="Auto"
                            Padding="10"
                            Text="Accept: application/json"
                            TextWrapping="NoWrap"
                            VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </TabItem>

                <TabItem Header="Body" Margin="0,0,-21,0">
                    <TabControl x:Name="BodyTypeTabControl">
                        <TabItem Header="Raw" Margin="0,0,-8,0">
                            <TextBox
                                x:Name="RequestBodyTextBox"
                                AcceptsReturn="True"
                                AcceptsTab="True"
                                FontFamily="Consolas"
                                FontSize="14"
                                HorizontalScrollBarVisibility="Auto"
                                Padding="10"
                                Text="{}"
                                TextWrapping="NoWrap"
                                VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Header="Form" Margin="0,0,-9,0">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button
                                    Grid.Row="0"
                                    Width="150"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="OpenFormFieldsDialogButton_Click"
                                    Content="编辑表单字段" />

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="{StaticResource AppGlassControlBackground}"
                                    BorderBrush="{StaticResource AppGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <TextBlock
                                        x:Name="FormFieldsSummaryTextBlock"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Multipart/File" Margin="0,0,-4,0">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button
                                    Grid.Row="0"
                                    Width="170"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="OpenMultipartEditorDialogButton_Click"
                                    Content="编辑表单和文件" />

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="{StaticResource AppGlassControlBackground}"
                                    BorderBrush="{StaticResource AppGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <TextBlock
                                        x:Name="MultipartSummaryTextBlock"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>

            <TabControl Grid.Row="2" Margin="0,10,0,0">
                <TabItem Header="Response Body" Margin="0,0,-9,-1">
                    <TextBox
                        x:Name="ResponseBodyTextBox"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="14"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Padding="10"
                        TextWrapping="NoWrap"
                        VerticalScrollBarVisibility="Auto" />
                </TabItem>

                <TabItem Header="Response Headers" Margin="0,0,-7,-1">
                    <TextBox
                        x:Name="ResponseHeadersTextBox"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="14"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Padding="10"
                        TextWrapping="NoWrap"
                        VerticalScrollBarVisibility="Auto" />
                </TabItem>

                <TabItem Header="Info" Margin="0,0,-12,-1">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Status Code" />
                        <TextBlock x:Name="StatusCodeTextBlock" Grid.Row="0" Grid.Column="1" />

                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Reason Phrase" />
                        <TextBlock x:Name="ReasonPhraseTextBlock" Grid.Row="1" Grid.Column="1" />

                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="Elapsed Time" />
                        <TextBlock x:Name="ElapsedTimeTextBlock" Grid.Row="2" Grid.Column="1" />

                        <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="Request Method" />
                        <TextBlock x:Name="RequestMethodTextBlock" Grid.Row="3" Grid.Column="1" />

                        <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="Request Url" />
                        <TextBlock x:Name="RequestUrlTextBlock" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
