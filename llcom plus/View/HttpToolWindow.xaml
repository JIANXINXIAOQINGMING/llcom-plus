<UserControl
    x:Class="llcom_plus.HttpToolWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    MinWidth="760"
    MinHeight="520"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0">
    <Grid>
        <Grid.Background>
            <ImageBrush
                ImageSource="pack://application:,,,/Assets/AppBackground.png"
                Opacity="0.58"
                Stretch="UniformToFill" />
        </Grid.Background>
        <Border Background="#24FFF8EC" Margin="0,0,0,129" />
        <Grid Margin="16">
            <Grid.Resources>
                <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type TextBox}" />
                <Style BasedOn="{StaticResource {x:Type DataGrid}}" TargetType="{x:Type DataGrid}" />
                <Style TargetType="{x:Type TabControl}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabControl}">
                                <Grid KeyboardNavigation.TabNavigation="Local">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TabPanel
                                        Margin="0,0,0,10"
                                        IsItemsHost="True"
                                        KeyboardNavigation.TabIndex="1"
                                        Panel.ZIndex="1" />
                                    <ContentPresenter
                                        x:Name="PART_SelectedContentHost"
                                        Grid.Row="1"
                                        ContentSource="SelectedContent"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Background" Value="{StaticResource AppGlassControlBackground}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Foreground" Value="{StaticResource AppGlassTextBrush}" />
                    <Setter Property="Padding" Value="16,7" />
                    <Setter Property="Margin" Value="0,0,5,0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Border
                                    x:Name="Chrome"
                                    MinHeight="34"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                    <ContentPresenter
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppGlassControlHoverBackground}" />
                                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppGlassFocusBorderBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppPopupBackground}" />
                                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
                    <Setter Property="MinHeight" Value="30" />
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="320" MinHeight="280" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,12"
                Padding="10"
                Background="{StaticResource AppGlassPanelBackground}"
                BorderBrush="{StaticResource AppGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        x:Name="MethodComboBox"
                        Grid.Column="0"
                        Height="36"
                        Margin="0,0,8,0"
                        SelectedIndex="0"
                        VerticalContentAlignment="Center">
                        <ComboBoxItem Content="{DynamicResource HttpMethodGet}" Tag="GET" />
                        <ComboBoxItem Content="{DynamicResource HttpMethodPost}" Tag="POST" />
                        <ComboBoxItem Content="{DynamicResource HttpMethodPut}" Tag="PUT" />
                        <ComboBoxItem Content="{DynamicResource HttpMethodDelete}" Tag="DELETE" />
                        <ComboBoxItem Content="{DynamicResource HttpMethodPatch}" Tag="PATCH" />
                        <ComboBoxItem Content="{DynamicResource HttpMethodHead}" Tag="HEAD" />
                    </ComboBox>

                    <ComboBox
                        x:Name="UrlSchemeComboBox"
                        Grid.Column="1"
                        Height="36"
                        Margin="0,0,8,0"
                        SelectedIndex="1"
                        VerticalContentAlignment="Center">
                        <ComboBoxItem Content="{DynamicResource HttpSchemeHttp}" Tag="http://" />
                        <ComboBoxItem Content="{DynamicResource HttpSchemeHttps}" Tag="https://" />
                    </ComboBox>

                    <TextBox
                        x:Name="UrlTextBox"
                        Grid.Column="2"
                        Height="36"
                        Margin="0,0,8,0"
                        VerticalContentAlignment="Center"
                        FontSize="14"
                        Text="postman-echo.com/get" />

                    <Button
                        x:Name="SendButton"
                        Grid.Column="3"
                        Height="36"
                        Background="#0E9AA7"
                        Click="SendButton_Click"
                        Content="{DynamicResource HttpSend}"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Margin="0,0,0,12">
                <TabItem Header="{DynamicResource HttpHeadersTab}" Margin="0,0,-5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                x:Name="HeaderPresetComboBox"
                                Grid.Column="0"
                                Height="34"
                                Margin="-8,0,8,0"
                                SelectionChanged="HeaderPresetComboBox_SelectionChanged"
                                VerticalContentAlignment="Center" />

                            <TextBox
                                x:Name="HeaderDefaultValueTextBox"
                                Grid.Column="1"
                                Height="34"
                                Margin="0,0,8,0"
                                VerticalContentAlignment="Center"
                                FontFamily="Consolas"
                                Text="application/json" />

                            <Button
                                Grid.Column="2"
                                Height="34"
                                Click="AddHeaderPresetButton_Click"
                                Content="{DynamicResource HttpAddOrUpdateHeader}" />
                        </Grid>

                        <TextBox
                            x:Name="RequestHeadersTextBox"
                            Grid.Row="1"
                            AcceptsReturn="True"
                            AcceptsTab="True"
                            FontFamily="Consolas"
                            FontSize="14"
                            HorizontalScrollBarVisibility="Auto"
                            Padding="10"
                            Text="Accept: application/json"
                            TextWrapping="NoWrap"
                            VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource HttpBodyTab}" Margin="0,0,-21,0">
                    <TabControl x:Name="BodyTypeTabControl">
                        <TabItem Header="{DynamicResource HttpRawTab}" Margin="0,0,-8,0">
                            <TextBox
                                x:Name="RequestBodyTextBox"
                                AcceptsReturn="True"
                                AcceptsTab="True"
                                FontFamily="Consolas"
                                FontSize="14"
                                HorizontalScrollBarVisibility="Auto"
                                Padding="10"
                                Text="{}"
                                TextWrapping="NoWrap"
                                VerticalScrollBarVisibility="Auto" />
                        </TabItem>

                        <TabItem Header="{DynamicResource HttpFormTab}" Margin="0,0,-9,0">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button
                                    Grid.Row="0"
                                    Width="150"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="OpenFormFieldsDialogButton_Click"
                                    Content="{DynamicResource HttpEditFormFields}" />

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="{StaticResource AppGlassControlBackground}"
                                    BorderBrush="{StaticResource AppGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <TextBlock
                                        x:Name="FormFieldsSummaryTextBlock"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="{DynamicResource HttpMultipartTab}" Margin="0,0,-4,0">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button
                                    Grid.Row="0"
                                    Width="170"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="OpenMultipartEditorDialogButton_Click"
                                    Content="{DynamicResource HttpEditFormAndFiles}" />

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="{StaticResource AppGlassControlBackground}"
                                    BorderBrush="{StaticResource AppGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <TextBlock
                                        x:Name="MultipartSummaryTextBlock"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>

                <TabItem Header="{DynamicResource HttpTlsTab}" Margin="17,0,-29,0">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="HttpTlsSettingsGrid" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsAuthMode}" />
                            <ComboBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,12,8"
                                SelectedIndex="{Binding tcpClientSslAuthMode}"
                                VerticalContentAlignment="Center">
                                <ComboBoxItem Content="{DynamicResource TlsAuthNone}" />
                                <ComboBoxItem Content="{DynamicResource TlsAuthOneWay}" />
                                <ComboBoxItem Content="{DynamicResource TlsAuthMutual}" />
                            </ComboBox>

                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsProtocolVersion}" />
                            <ComboBox
                                Grid.Row="0"
                                Grid.Column="3"
                                Margin="0,0,0,8"
                                SelectedIndex="{Binding tcpClientSslProtocolType}"
                                VerticalContentAlignment="Center">
                                <ComboBoxItem Content="{DynamicResource TlsProtocolAuto}" />
                                <ComboBoxItem Content="{DynamicResource TlsProtocolTls10}" />
                                <ComboBoxItem Content="{DynamicResource TlsProtocolTls11}" />
                                <ComboBoxItem Content="{DynamicResource TlsProtocolTls12}" />
                                <ComboBoxItem Content="{DynamicResource TlsProtocolTls13}" />
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsTargetHost}" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,12,8"
                                ToolTip="{DynamicResource TlsTargetHostTipHttp}"
                                Text="{Binding tcpClientSslTargetHost, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox
                                Grid.Row="1"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,8"
                                VerticalAlignment="Center"
                                Content="{DynamicResource TlsCheckRevocation}"
                                IsChecked="{Binding tcpClientSslCheckRevocation}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsTrustedCa}" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,8"
                                Text="{Binding tcpClientSslCaCertPath, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsClientCert}" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,8"
                                Text="{Binding tcpClientSslClientCertPath, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsClientKey}" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,8"
                                Text="{Binding tcpClientSslClientKeyPath, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsCertPassword}" />
                            <TextBox
                                Grid.Row="5"
                                Grid.Column="1"
                                Margin="0,0,12,8"
                                Text="{Binding tcpClientSslClientCertPassword, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox
                                Grid.Row="5"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Margin="0,0,0,8"
                                VerticalAlignment="Center"
                                Content="{DynamicResource TlsPrintDetails}"
                                IsChecked="{Binding tcpClientSslPrintDetails}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="{DynamicResource TlsCipherSuites}" />
                            <ComboBox
                                x:Name="HttpCipherSuitesPicker"
                                Grid.Row="6"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,8"
                                IsEditable="True"
                                IsReadOnly="True"
                                IsTextSearchEnabled="False"
                                MaxDropDownHeight="320"
                                StaysOpenOnEdit="True"
                                ToolTip="{DynamicResource TlsCipherSuitesTip}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="{DynamicResource TlsOpenSslPath}" />
                            <TextBox
                                Grid.Row="7"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                ToolTip="{DynamicResource TlsOpenSslPathTip}"
                                Text="{Binding openSslPath, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <TabControl Grid.Row="2" Margin="0,10,0,0">
                <TabItem Header="{DynamicResource HttpResponseBodyTab}" Margin="0,0,-9,-1">
                    <TextBox
                        x:Name="ResponseBodyTextBox"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="14"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Padding="10"
                        TextWrapping="NoWrap"
                        VerticalScrollBarVisibility="Auto" />
                </TabItem>

                <TabItem Header="{DynamicResource HttpResponseHeadersTab}" Margin="0,0,-7,-1">
                    <TextBox
                        x:Name="ResponseHeadersTextBox"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="14"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Padding="10"
                        TextWrapping="NoWrap"
                        VerticalScrollBarVisibility="Auto" />
                </TabItem>

                <TabItem Header="{DynamicResource HttpInfoTab}" Margin="0,0,-12,-1">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" FontWeight="SemiBold" Text="{DynamicResource HttpStatusCode}" />
                            <TextBlock x:Name="StatusCodeTextBlock" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" FontWeight="SemiBold" Text="{DynamicResource HttpReasonPhrase}" />
                            <TextBlock x:Name="ReasonPhraseTextBlock" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" FontWeight="SemiBold" Text="{DynamicResource HttpElapsedTime}" />
                            <TextBlock x:Name="ElapsedTimeTextBlock" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" FontWeight="SemiBold" Text="{DynamicResource HttpRequestMethod}" />
                            <TextBlock x:Name="RequestMethodTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,0" FontWeight="SemiBold" Text="{DynamicResource HttpRequestUrl}" />
                            <TextBlock x:Name="RequestUrlTextBlock" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
