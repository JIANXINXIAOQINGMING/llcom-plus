<Window
    x:Class="llcom_plus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:local="clr-namespace:llcom_plus"
    xmlns:local_page="clr-namespace:llcom_plus.Pages"
    xmlns:local_tool="clr-namespace:llcom_plus.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{DynamicResource AppTitle}"
    Width="1660"
    Height="820"
    MinWidth="1500"
    MinHeight="760"
    Icon="pack://application:,,,/Assets/AppIcon.ico"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0"
    Activated="Window_Activated"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded"
    mc:Ignorable="d">
    <Window.Style>
        <Style BasedOn="{StaticResource {x:Type Window}}" TargetType="Window" />
    </Window.Style>
    <Window.Resources>
        <RoutedUICommand x:Key="SendUartData" Text="SendUartData" />
        <local_page:boolVisibe x:Key="boolVisibeConverter" />
        <local_page:boolNotVisibe x:Key="boolNotVisibeConverter" />
        <local_page:rsTooltip x:Key="rsToolTipConverter" />
        <local_page:rsOpacity x:Key="rsOpacityConverter" />
        <local_page:boolOpacity x:Key="boolOpacityConverter" />
        <Style x:Key="GlassPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource AppGlassPanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppGlassPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="18"
                        Direction="270"
                        Opacity="0.18"
                        ShadowDepth="3"
                        Color="#5C4B3B" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassPanelTightStyle" BasedOn="{StaticResource GlassPanelStyle}" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="12"
                        Direction="270"
                        Opacity="0.14"
                        ShadowDepth="2"
                        Color="#5C4B3B" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="GlassTextBoxStyle" BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource AppGlassInputBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
        <Style x:Key="GlassTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,18"
                                Padding="0,6,6,6"
                                Background="{StaticResource AppTabStripBackground}"
                                BorderBrush="{StaticResource AppTabStripBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <TabPanel
                                    IsItemsHost="True"
                                    KeyboardNavigation.TabIndex="1"
                                    Panel.ZIndex="1" />
                            </Border>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter
                                    x:Name="PART_SelectedContentHost"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Background" Value="{StaticResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource AppGlassTextBrush}" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="20,7" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border
                            x:Name="Chrome"
                            MinHeight="31"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppGlassControlHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppGlassFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppPopupBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolListBoxStyle" BasedOn="{StaticResource {x:Type ListBox}}" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="ToolListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border
                            x:Name="Chrome"
                            MinHeight="38"
                            Padding="{TemplateBinding Padding}"
                            Background="{StaticResource AppGlassControlBackground}"
                            BorderBrush="{StaticResource AppGlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="9">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppGlassControlHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppGlassFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppPopupBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatusPillStyle" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{StaticResource AppGlassControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
        <Style x:Key="StatusLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource AppGlassMutedBrush}" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>
        <Style x:Key="StatusValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AppGlassTextBrush}" />
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding
            Key="Return"
            Command="{StaticResource SendUartData}"
            Gesture="Ctrl+Return" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{StaticResource SendUartData}" Executed="SendUartData_Executed" />
    </Window.CommandBindings>
    <Grid Name="MainGrid" IsEnabled="False">
        <Grid.Background>
            <ImageBrush
                ImageSource="pack://application:,,,/Assets/AppBackground.png"
                Opacity="0.58"
                Stretch="UniformToFill" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="23*" MinWidth="430" />
            <ColumnDefinition Width="125*"/>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="1040" MinWidth="980" />
        </Grid.ColumnDefinitions>
        <Border
            Grid.RowSpan="3"
            Grid.ColumnSpan="4"
            Background="{StaticResource AppWindowOverlayBrush}"
            IsHitTestVisible="False" />

        <!--  收发数据显示  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="10,10,6,6"
            Padding="6"
            Style="{StaticResource GlassPanelStyle}" Grid.ColumnSpan="2">
            <Frame
                Name="dataShowFrame"
                Background="Transparent"
                BorderBrush="#00000000"
                BorderThickness="0.5"
                GotFocus="uartDataFlowDocument_GotFocus"
                LostFocus="uartDataFlowDocument_LostFocus"
                NavigationUIVisibility="Hidden"
                PreviewKeyDown="uartDataFlowDocument_PreviewKeyDown"
                PreviewTextInput="uartDataFlowDocument_PreviewTextInput" />
        </Border>

        <!--  发送数据区  -->
        <Border
            Grid.Row="1"
            Margin="10,4,6,8"
            Padding="6"
            Style="{StaticResource GlassPanelTightStyle}" Grid.ColumnSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="55" />
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <Button
                Name="openClosePortButton"
                Grid.RowSpan="3"
                Grid.Column="3"
                Margin="2"
                Style="{StaticResource GlassButtonStyle}"
                Click="OpenClosePortButton_Click">
                    <WrapPanel>
                        <TextBlock Name="openClosePortTextBlock" Text="{DynamicResource OpenPort_open}" />
                        <TextBlock Text="{DynamicResource OpenPort_port}" />
                    </WrapPanel>
                </Button>
                <Button
                Name="clearLogButton"
                Grid.Column="4"
                Margin="2"
                Style="{StaticResource GlassButtonStyle}"
                Click="ClearLogButton_Click"
                Content="{DynamicResource ClearLog}" />
                <Button
                Name="FlowControlButton"
                Grid.Row="1"
                Grid.Column="4"
                Margin="2"
                Style="{StaticResource GlassButtonStyle}"
                Click="FlowControlButton_Click"
                Content="{DynamicResource FlowControlButton}"
                ToolTip="{DynamicResource FlowControlButtonTip}" />
                <Button
                Name="MoreSettingButton"
                Grid.Row="2"
                Grid.Column="4"
                Margin="2"
                Style="{StaticResource GlassButtonStyle}"
                Click="MoreSettingButton_Click"
                Content="{DynamicResource MoreSettings}"
                ToolTip="{DynamicResource MoreSettingsTip}" />
                <TextBox
                Name="toSendDataTextBox"
                Grid.RowSpan="3"
                Grid.Column="5"
                Height="75"
                Margin="2"
                Style="{StaticResource GlassTextBoxStyle}"
                VerticalContentAlignment="Top"
                AcceptsReturn="True"
                FontFamily="Consolas"
                PreviewKeyDown="ToSendDataTextBox_PreviewKeyDown"
                Text="{Binding dataToSend}"
                TextChanged="ToSendDataTextBox_TextChanged"
                TextWrapping="Wrap"
                LostFocus="ToSendDataTextBox_LostFocus"
                VerticalScrollBarVisibility="Auto" />
                <Popup
                Name="sendSuggestPopup"
                Grid.RowSpan="3"
                Grid.Column="5"
                AllowsTransparency="True"
                Placement="Top"
                PlacementTarget="{Binding ElementName=toSendDataTextBox}"
                StaysOpen="False"
                VerticalOffset="-4">
                    <Border
                    Padding="3"
                    Background="{StaticResource AppPopupBackground}"
                    BorderBrush="{StaticResource AppGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                        <ListBox
                        Name="sendSuggestListBox"
                        MinHeight="26"
                        MaxHeight="180"
                        Width="{Binding ElementName=toSendDataTextBox, Path=ActualWidth}"
                        FontFamily="Consolas"
                        MouseDoubleClick="SendSuggestListBox_MouseDoubleClick" />
                    </Border>
                </Popup>
                <Button
                Name="sendDataButton"
                Grid.RowSpan="3"
                Grid.Column="6"
                Margin="2"
                Style="{StaticResource GlassButtonStyle}"
                Command="{StaticResource SendUartData}"
                Content="{DynamicResource SendDataButton}"
                ToolTip="{DynamicResource SendDataButtonTip}" />
            </Grid>
        </Border>


        <!--  底部状态栏  -->
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="4"
            Margin="10,0,10,10"
            Padding="4"
            Style="{StaticResource GlassPanelTightStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                Name="refreshPortButton"
                Grid.Column="0"
                MinHeight="32"
                Margin="0,0,8,0"
                Style="{StaticResource GlassButtonStyle}"
                Click="RefreshPortButton_Click"
                Content="{DynamicResource RefreshPortButton}"
                IsEnabled="{Binding ElementName=serialPortsListComboBox, Path=IsEnabled}" />
                <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                    <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource ShowPorts}" />
                    <ComboBox
                    Name="serialPortsListComboBox"
                    MinWidth="190"
                    MaxWidth="320"
                    Margin="0,0,12,0" />
                    <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Text="{DynamicResource ShowBaudRate}" />
                    <ComboBox
                    Name="baudRateComboBox"
                    Width="90"
                    DropDownClosed="BaudRateComboBox_Changed"
                    DropDownOpened="BaudRateComboBox_Changed">
                        <ComboBoxItem Content="110" />
                        <ComboBoxItem Content="330" />
                        <ComboBoxItem Content="600" />
                        <ComboBoxItem Content="1200" />
                        <ComboBoxItem Content="2400" />
                        <ComboBoxItem Content="4800" />
                        <ComboBoxItem Content="9600" />
                        <ComboBoxItem Content="14400" />
                        <ComboBoxItem Content="19200" />
                        <ComboBoxItem Content="38400" />
                        <ComboBoxItem Content="56000" />
                        <ComboBoxItem Content="57600" />
                        <ComboBoxItem Content="115200" />
                        <ComboBoxItem Content="128000" />
                        <ComboBoxItem Content="230400" />
                        <ComboBoxItem Content="256000" />
                        <ComboBoxItem Content="460800" />
                        <ComboBoxItem Content="500000" />
                        <ComboBoxItem Content="128000" />
                        <ComboBoxItem Content="512000" />
                        <ComboBoxItem Content="600000" />
                        <ComboBoxItem Content="750000" />
                        <ComboBoxItem Content="921600" />
                        <ComboBoxItem Content="1000000" />
                        <ComboBoxItem Content="1500000" />
                        <ComboBoxItem Content="2000000" />
                        <ComboBoxItem Content="3000000" />
                        <ComboBoxItem Content="{DynamicResource OtherRate}" />
                    </ComboBox>
                    <ComboBox
                    Name="showHexFormatComboBox"
                    Width="150"
                    Margin="12,0,0,0"
                    SelectedIndex="{Binding showHexFormat}"
                    ToolTip="{DynamicResource ShowHexFormatTip}">
                        <ComboBoxItem Content="{DynamicResource SettingShowBoth}" />
                        <ComboBoxItem Content="{DynamicResource SettingShoText}" />
                        <ComboBoxItem Content="{DynamicResource SettingShowHexOnly}" />
                    </ComboBox>
                </StackPanel>
                <StackPanel
                Grid.Column="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                    <Border Style="{StaticResource StatusPillStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource StatusLabelStyle}" Text="{DynamicResource ShowStatus}" />
                            <TextBlock Name="statusTextBlock" Style="{StaticResource StatusValueStyle}" Text="{DynamicResource OpenPort_close}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusPillStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                            Cursor="Cross"
                            MouseRightButtonDown="sentCountTextBlock_MouseRightButtonDown"
                            Style="{StaticResource StatusLabelStyle}"
                            Text="{DynamicResource SentCount}"
                            ToolTip="{DynamicResource ClearCountTip}" />
                            <TextBlock
                            Name="sentCountTextBlock"
                            Cursor="Cross"
                            MouseRightButtonDown="sentCountTextBlock_MouseRightButtonDown"
                            Style="{StaticResource StatusValueStyle}"
                            Text="{Binding SentCount}"
                            ToolTip="{DynamicResource ClearCountTip}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusPillStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                            Cursor="Cross"
                            MouseRightButtonDown="receivedCountTextBlock_MouseRightButtonDown"
                            Style="{StaticResource StatusLabelStyle}"
                            Text="{DynamicResource ReceivedCount}"
                            ToolTip="{DynamicResource ClearCountTip}" />
                            <TextBlock
                            Name="receivedCountTextBlock"
                            Cursor="Cross"
                            MouseRightButtonDown="receivedCountTextBlock_MouseRightButtonDown"
                            Style="{StaticResource StatusValueStyle}"
                            Text="{Binding ReceivedCount}"
                            ToolTip="{DynamicResource ClearCountTip}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!--  中间改变分割大小的东西  -->
        <GridSplitter
            Grid.RowSpan="2"
            Grid.Column="2"
            Width="8"
            Margin="0,10,0,8"
            HorizontalAlignment="Stretch"
            Background="#66FFFFFF" />

        <!--  右侧脚本、快捷发送  -->
        <Border
            Grid.RowSpan="2"
            Grid.Column="3"
            MinWidth="660"
            Margin="12,14,14,8"
            Padding="12"
            Style="{StaticResource GlassPanelStyle}">
            <TabControl
            Name="MainTabControl"
            Background="Transparent"
            BorderThickness="0"
            Style="{StaticResource GlassTabControlStyle}"
            ItemContainerStyle="{StaticResource GlassTabItemStyle}"
            SelectionChanged="MainTabControl_SelectionChanged">
                <TabItem Name="QuickSendTab" Header="{DynamicResource QuickSendCard}" Margin="0,3,0,-9" Width="136">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <Grid.Resources>
                            <Style x:Key="toSendListStyle" TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Grid Name="ItemGrid" Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="4*" />
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="46" />
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="0" />
                                                </Grid.ColumnDefinitions>
                                                <Grid
                                                Margin="1"
                                                Background="Transparent"
                                                Cursor="Cross"
                                                MouseRightButtonDown="TextBlock_MouseRightButtonDown"
                                                Tag="{Binding}" />
                                                <TextBlock
                                                Grid.Column="0"
                                                Margin="2"
                                                HorizontalAlignment="Center"
                                                Cursor="Cross"
                                                MouseRightButtonDown="TextBlock_MouseRightButtonDown"
                                                Tag="{Binding}"
                                                Text="{Binding id}"
                                                ToolTip="{DynamicResource QuickSendIdTip}" />
                                                <TextBox
                                                Grid.Column="1"
                                                Margin="0,0,2,0"
                                                HorizontalAlignment="Stretch"
                                                Text="{Binding text, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button
                                                Grid.Column="2"
                                                MinWidth="58"
                                                HorizontalAlignment="Stretch"
                                                Click="knowSendDataButton_click"
                                                Content="{DynamicResource QuickSendButton}"
                                                Cursor="Cross"
                                                Tag="{Binding}"
                                                ToolTip="{DynamicResource QuickSendButtonTip}" />
                                                <CheckBox
                                                Grid.Column="3"
                                                Margin="2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding hex}" />
                                                <TextBlock
                                                Name="recvScriptSet"
                                                Grid.Column="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Opacity="{Binding recvScriptPath, Converter={StaticResource rsOpacityConverter}}"
                                                MouseLeftButtonDown="ScriptIcon_Click"
                                                MouseRightButtonDown="ScriptIcon_RightClick"
                                                Tag="{Binding}">
                                                <fa:FontAwesome Foreground="DimGray" Icon="FileText">
                                                    <fa:FontAwesome.Style>
                                                        <Style TargetType="fa:FontAwesome">
                                                            <Setter Property="FontSize" Value="16"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="FontSize" Value="20"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </fa:FontAwesome.Style>
                                                </fa:FontAwesome>
                                                    <TextBlock.ToolTip>
                                                        <MultiBinding Converter="{StaticResource rsToolTipConverter}">
                                                            <Binding Path="recvScriptPath" UpdateSourceTrigger="PropertyChanged"/>
                                                            <Binding ElementName="sendDataButton" Path="Content" UpdateSourceTrigger="PropertyChanged" Delay="1000"/>
                                                        </MultiBinding>
                                                    </TextBlock.ToolTip>
                                                </TextBlock>
                                                <TextBlock
                                                Visibility="Collapsed"
                                                Name="recvScriptPara"
                                                Grid.Column="6"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Opacity="{Binding recvScriptPara, Converter={StaticResource rsOpacityConverter}}"
                                                MouseLeftButtonUp="ScriptParaIcon_Click"
                                                MouseRightButtonDown="ScriptParaIcon_RightClick"
                                                Tag="{Binding}"
                                                ToolTip="{DynamicResource QuickSendRecvScriptParaSet}">
                                                <fa:FontAwesome Foreground="DimGray" Icon="Cog">
                                                    <fa:FontAwesome.Style>
                                                        <Style TargetType="fa:FontAwesome">
                                                            <Setter Property="FontSize" Value="18"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="FontSize" Value="22"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </fa:FontAwesome.Style>
                                                </fa:FontAwesome>
                                                </TextBlock>
                                                <Button
                                                Grid.Column="5"
                                                Width="28"
                                                Height="24"
                                                Margin="3,0,0,0"
                                                Padding="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Click="RemoveSendListItemButton_Click"
                                                Content="−"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="#9B3333"
                                                Style="{StaticResource GlassButtonStyle}"
                                                Tag="{Binding}"
                                                ToolTip="{DynamicResource QuickSendRemoveItem}" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="ItemGrid" Property="Background" Value="Transparent" />
                                                </Trigger>
                                                <Trigger Property="Selector.IsSelected" Value="true">
                                                    <Setter TargetName="ItemGrid" Property="Background" Value="Transparent" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,8">
                                <ComboBox
                                Name="QuickListSelectComboBox"
                                Width="76"
                                MaxDropDownHeight="280"
                                HorizontalAlignment="Left"
                                SelectionChanged="QuickListSelectComboBox_SelectionChanged" />
                                <TextBox
                                Name="QuickListNameTextBox"
                                MinWidth="180"
                                MaxWidth="280"
                                Margin="8,0,0,0"
                                VerticalContentAlignment="Center"
                                TextChanged="QuickListNameTextBox_TextChanged"
                                ToolTip="{DynamicResource QuickSendListNameTip}" />
                            </DockPanel>
                            <Grid Grid.Row="1" Margin="0,0,18,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="0" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Text="{DynamicResource QuickSendId}" />
                                <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Text="{DynamicResource QuickSendContent}" />
                                <TextBlock
                                Grid.Column="3"
                                HorizontalAlignment="Center"
                                Text="{DynamicResource QuickSendHex}" />
                                <TextBlock
                                Grid.Column="4"
                                HorizontalAlignment="Center"
                                Text="{DynamicResource QuickSendRecvScript}" />
                            </Grid>
                        </Grid>
                        <ListBox
                        Name="toSendList"
                        Grid.Row="1"
                        ItemContainerStyle="{StaticResource toSendListStyle}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        VirtualizingPanel.CacheLength="1,2"
                        VirtualizingPanel.CacheLengthUnit="Page"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling" />
                        <Popup Name="recvScriptPopup" Placement="Bottom" VerticalOffset="5" StaysOpen="True">
                            <ComboBox Name="recvScriptCombo" Width="250" DropDownClosed="recvScriptCombo_DropDownClosed"/>
                        </Popup>
                        <Popup Name="recvScriptParaPopup" Placement="Bottom" VerticalOffset="5" StaysOpen="False">
                            <Grid Background="{StaticResource AppPopupBackground}">
                                <Border
                                BorderBrush="{StaticResource AppGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                    <TextBox
                                    Name="recvScriptParaBox" 
                                    Margin="3"
                                    Width="250" Height="100" 
                                    AcceptsReturn="True"
                                    HorizontalContentAlignment="Left"
                                    TextWrapping="Wrap"
                                    VerticalContentAlignment="Top"
                                    VerticalScrollBarVisibility="Auto" />
                                </Border>
                                <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,3,0" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Name="rsParaConfirm" Grid.Column="0" Tag="{Binding ElementName=recvScriptParaBox}" MouseLeftButtonUp="ScriptParaConfirm_Click">
                                    <fa:FontAwesome Icon="Check" Foreground="Green" FontSize="18"/>
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Opacity" Value="0.25"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Name="rsParaCancel" Grid.Column="1" MouseLeftButtonUp="ScriptParaCancel_Click">
                                    <fa:FontAwesome Icon="Times" Foreground="Red" FontSize="18"/>
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Opacity" Value="0.25"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Popup>
                        <StackPanel Grid.Row="2">
                            <Button
                            Name="addSendListButton"
                            Height="34"
                            Margin="3,8,3,3"
                            Click="AddSendListButton_Click"
                            Content="＋"
                            FontSize="22"
                            FontWeight="Bold"
                            Style="{StaticResource GlassButtonStyle}"
                            ToolTip="{DynamicResource QuickSendAdd}" />
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                Name="QuickSendImportButton"
                                Margin="3"
                                Click="QuickSendImportButton_Click"
                                Content="{DynamicResource QuickSendImport}" />
                                <Button
                                Name="QuickSendExportButton"
                                Grid.Column="1"
                                Margin="3"
                                Click="QuickSendExportButton_Click"
                                Content="{DynamicResource QuickSendExport}" />
                                <Button
                                Name="QuickSendExportAllButton"
                                Grid.Column="2"
                                Margin="3"
                                Click="QuickSendExportAllButton_Click"
                                Content="{DynamicResource QuickSendExportAll}" />
                            </Grid>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                Name="AddQuickSendPageButton"
                                Grid.Column="0"
                                Margin="3"
                                Click="AddQuickSendPageButton_Click"
                                Content="{DynamicResource QuickSendAddPage}" />
                                <Button
                                Name="DeleteQuickSendPageButton"
                                Grid.Column="1"
                                Margin="3"
                                Click="DeleteQuickSendPageButton_Click"
                                Content="{DynamicResource QuickSendDeletePage}" />
                            </Grid>

                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Name="ScriptTab" Header="{DynamicResource ScriptCard}" Margin="0,2,0,-8" Width="136">
                    <Grid>
                        <!--  脚本编辑界面  -->
                        <Grid Name="scriptEditorGrid" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel Margin="0,0,0,5" Orientation="Horizontal">
                                <ComboBox
                                Name="scriptFileList"
                                Width="260"
                                SelectionChanged="ScriptFileList_SelectionChanged" />
                                <Button
                                Name="newScriptButton"
                                Margin="3,0,0,0"
                                Click="NewScriptButton_Click"
                                ToolTip="{DynamicResource ScriptNewScript}">
                                    <Grid>
                                        <fa:FontAwesome Foreground="LightSkyBlue" Icon="File" />
                                        <fa:FontAwesome Icon="FileCodeOutline" />
                                    </Grid>
                                </Button>
                                <Button
                                Name="runScriptButton"
                                Margin="2,0,0,0"
                                Click="RunScriptButton_Click"
                                ToolTip="{DynamicResource ScriptRunScript}">
                                    <fa:FontAwesome Foreground="DarkGreen" Icon="Play" />
                                </Button>
                                <Button
                                Name="openScriptFolderButton"
                                Margin="2,0,0,0"
                                Click="OpenScriptFolderButton_Click"
                                ToolTip="{DynamicResource ScriptOpenFolder}">
                                    <Grid>
                                        <fa:FontAwesome Foreground="Yellow" Icon="FolderOpen" />
                                        <fa:FontAwesome Icon="FolderOutlinepenOutline" />
                                    </Grid>
                                </Button>
                                <Button
                                Name="refreshScriptListButton"
                                Margin="2,0,0,0"
                                Click="RefreshScriptListButton_Click"
                                ToolTip="{DynamicResource ScriptRefreshList}">
                                    <fa:FontAwesome Foreground="Green" Icon="Refresh" />
                                </Button>
                                <Button
                                Name="apiDocumentButton"
                                Margin="2,0,0,0"
                                Click="ApiDocumentButton_Click"
                                ToolTip="{DynamicResource ScriptApiReference}">
                                    <fa:FontAwesome Foreground="DarkSlateGray" Icon="Book" />
                                </Button>
                            </WrapPanel>
                            <WrapPanel
                            Name="newScriptFileWrapPanel"
                            Grid.Row="1"
                            Margin="3"
                            Visibility="Collapsed">
                                <TextBlock VerticalAlignment="Center" Text="{DynamicResource ScriptFileName}" />
                                <TextBox
                                Name="newScriptFileNameTextBox"
                                Width="90"
                                Text="new script" />
                                <Button
                                Name="newScriptFileButton"
                                Margin="3,0,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Click="NewScriptFileButton_Click"
                                ToolTip="{DynamicResource ScriptConfirmCreate}">
                                    <fa:FontAwesome Foreground="Green" Icon="Check" />
                                </Button>
                                <Button
                                Name="newScriptFileCancelButton"
                                Margin="3,0,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Click="NewScriptFileCancelButton_Click"
                                ToolTip="{DynamicResource ScriptCancel}">
                                    <fa:FontAwesome Foreground="Red" Icon="Ban" />
                                </Button>
                            </WrapPanel>
                            <avalonEdit:TextEditor
                            xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
                            Name="textEditor"
                            Grid.Row="2"
                            FontFamily="Consolas"
                            FontSize="10pt"
                            LostFocus="TextEditor_LostFocus"
                            ShowLineNumbers="True"
                            TextChanged="textEditor_TextChanged" />
                        </Grid>
                        <!--  脚本编辑界面END  -->

                        <!--  脚本运行日志界面  -->
                        <Grid Name="scriptLogShowGrid" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <TextBox
                            Name="scriptLogTextBox"
                            VerticalContentAlignment="Top"
                            IsReadOnly="true"
                            MouseLeave="scriptLogTextBox_MouseLeave"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                Name="stopScriptButton"
                                Margin="0,3,3,3"
                                Click="StopScriptButton_Click"
                                Foreground="DarkRed"
                                ToolTip="{DynamicResource ScriptStop}">
                                    <fa:FontAwesome Name="stopScriptOrExitIcon" Icon="Stop" />
                                </Button>
                                <Button
                                Name="pauseScriptPrintButton"
                                Grid.Column="1"
                                Margin="0,3,3,3"
                                Click="PauseScriptPrintButton_Click"
                                Foreground="ForestGreen"
                                MouseRightButtonUp="pauseScriptPrintButton_MouseRightButtonUp"
                                ToolTip="{DynamicResource ScriptPause}">
                                    <fa:FontAwesome Name="pauseScriptPrintIcon" Icon="Pause" />
                                </Button>
                                <TextBox
                                Name="runOneLineScriptTextBox"
                                Grid.Column="2"
                                Margin="0,3"
                                KeyDown="RunOneLineScriptTextBox_KeyDown" />
                                <Button
                                Name="sendScriptCommandButton"
                                Grid.Column="3"
                                Margin="3,3,0,3"
                                Click="SendScriptCommandButton_Click"
                                Foreground="DeepSkyBlue"
                                ToolTip="{DynamicResource ScriptSendCommand}">
                                    <fa:FontAwesome Icon="ArrowUp" />
                                </Button>
                            </Grid>
                        </Grid>
                        <!--  脚本运行日志界面END  -->
                    </Grid>
                </TabItem>
                <TabItem Name="ToolsTab" Header="{DynamicResource ToolsTab}" Margin="0,2,0,-8" Width="136">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                        Grid.Column="0"
                        Padding="6"
                        Style="{StaticResource GlassPanelTightStyle}">
                            <ListBox
                            Name="ToolListBox"
                            DisplayMemberPath="Title"
                            ItemContainerStyle="{StaticResource ToolListItemStyle}"
                            SelectionChanged="ToolListBox_SelectionChanged"
                            Style="{StaticResource ToolListBoxStyle}" />
                        </Border>
                        <Border
                        Grid.Column="2"
                        Padding="8"
                        Background="{StaticResource AppToolContentBackground}"
                        BorderBrush="{StaticResource AppGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                            <ContentControl Name="ToolContentHost" />
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Name="AboutTab" Header="{DynamicResource AboutCard}" Margin="0,2,0,-8" Width="136">
                    <Frame Name="aboutFrame" NavigationUIVisibility="Hidden" />
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel
            Grid.Column="3"
            Margin="0,18,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <Button
                Name="ThemeToggleMenuItem"
                Width="26"
                Height="26"
                Margin="0,0,4,0"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Click="ThemeToggleMenuItem_Click"
                ToolTip="{DynamicResource DarkMode}">
                <fa:FontAwesome
                    Name="ThemeToggleIcon"
                    Foreground="{StaticResource AppAccentBrush}"
                    Icon="Adjust" />
            </Button>
            <Menu Background="Transparent" BorderThickness="0">
                <MenuItem
                    Width="26"
                    Height="26"
                    Padding="0"
                    ToolTip="{DynamicResource ChangeLanguage}">
                    <MenuItem.Header>
                        <fa:FontAwesome Foreground="Blue" Icon="Globe" />
                    </MenuItem.Header>
                    <MenuItem
                        Click="MenuItem_Click"
                        Header="简体中文"
                        Tag="zh-CN" />
                    <MenuItem
                        Click="MenuItem_Click"
                        Header="English"
                        Tag="en-US" />
                </MenuItem>
            </Menu>
        </StackPanel>
    </Grid>
</Window>
