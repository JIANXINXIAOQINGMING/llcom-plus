<Page
    x:Class="llcom_plus.Pages.CircularSendPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="620"
    d:DesignWidth="920"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8" LastChildFill="False">
            <TextBlock
                DockPanel.Dock="Left"
                VerticalAlignment="Center"
                FontSize="18"
                FontWeight="Bold"
                Text="{DynamicResource CircularSendToolTab}" />
            <Button
                DockPanel.Dock="Right"
                MinWidth="92"
                Margin="6,0,0,0"
                Click="ImportQuickSendButton_Click"
                Content="{DynamicResource CircularSendImportQuickSend}" />
            <Button
                DockPanel.Dock="Right"
                MinWidth="80"
                Margin="6,0,0,0"
                Click="ClearButton_Click"
                Content="{DynamicResource CircularSendClear}" />
            <Button
                DockPanel.Dock="Right"
                MinWidth="80"
                Margin="6,0,0,0"
                Click="AddRowButton_Click"
                Content="{DynamicResource CircularSendAddRow}" />
            <Button
                DockPanel.Dock="Right"
                MinWidth="80"
                Margin="6,0,0,0"
                Click="SelectAllButton_Click"
                Content="{DynamicResource CircularSendSelectAll}" />
            <Button
                DockPanel.Dock="Right"
                MinWidth="80"
                Margin="6,0,0,0"
                Click="ClearSelectionButton_Click"
                Content="{DynamicResource CircularSendClearSelection}" />
        </DockPanel>

        <DataGrid
            x:Name="CommandDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            CanUserSortColumns="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            ItemsSource="{Binding Items}"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Width="58" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendEnabled}" />
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Width="54" Binding="{Binding Index}" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendIndex}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="*" Binding="{Binding Command, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendCommand}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Width="58" Binding="{Binding Hex, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendHex}" />
                    </DataGridCheckBoxColumn.Header>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Width="92" Binding="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendDelay}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="120" Binding="{Binding Status}" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource CircularSendStatus}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="112">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    MinWidth="42"
                                    Margin="0,0,4,0"
                                    Click="SendOneButton_Click"
                                    Content="{DynamicResource CircularSendSendOne}"
                                    Tag="{Binding}" />
                                <Button
                                    MinWidth="42"
                                    Click="RemoveRowButton_Click"
                                    Content="{DynamicResource CircularSendRemoveRow}"
                                    Tag="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="2"
            Margin="0,8,0,0"
            Padding="8"
            BorderBrush="#D5E4EF"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="86" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="104" />
                    <ColumnDefinition Width="88" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{DynamicResource CircularSendTimes}" />
                <TextBox
                    x:Name="RunTimesTextBox"
                    Grid.Column="1"
                    Margin="6,0,14,0"
                    HorizontalContentAlignment="Center"
                    Text="1"
                    ToolTip="{DynamicResource CircularSendTimesTip}" />
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{DynamicResource CircularSendDefaultDelay}" />
                <TextBox
                    x:Name="DefaultDelayTextBox"
                    Grid.Column="3"
                    Margin="6,0,14,0"
                    HorizontalContentAlignment="Center"
                    Text="1000"
                    ToolTip="{DynamicResource CircularSendDefaultDelayTip}" />
                <TextBlock
                    x:Name="StatusTextBlock"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Text="{DynamicResource CircularSendIdle}" />
                <Button
                    x:Name="StartButton"
                    Grid.Column="5"
                    Margin="4,0"
                    Click="StartButton_Click"
                    Content="{DynamicResource CircularSendStart}" />
                <Button
                    x:Name="StopButton"
                    Grid.Column="6"
                    Margin="4,0"
                    Click="StopButton_Click"
                    Content="{DynamicResource CircularSendStop}"
                    IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Page>
