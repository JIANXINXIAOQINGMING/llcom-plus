<Page
    x:Class="llcom_plus.Pages.DataShowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:local="clr-namespace:llcom_plus.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DataShowPage"
    adonisExtensions:RippleExtension.FadeInDuration="0"
    adonisExtensions:RippleExtension.FadeOutDuration="0"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <local:boolVisibe x:Key="boolVisibeConverter" />
        <local:boolNotVisibe x:Key="boolNotVisibeConverter" />
        <Style x:Key="DataShowStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <RichTextBox
                            Name="ItemGrid"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas,Microsoft YaHei,微软雅黑"
                            FontSize="12"
                            IsReadOnly="True">
                            <FlowDocument>
                                <Paragraph Margin="0">
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding TimeText}" />
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding ArrowText}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding DataTextColor}"
                                        Text="{Binding DataText}" />
                                    <Run
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AppGlassTextBrush}"
                                        Text="{Binding RawTitle}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding RawTextColor}"
                                        Text="{Binding RawText}" />
                                    <Run Foreground="{Binding HexTextColor}" Text="{Binding HexText}" />
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="ItemGrid" Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="Selector.IsSelected" Value="true">
                                <Setter TargetName="ItemGrid" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LogOptionCheckBoxStyle" BasedOn="{StaticResource {x:Type CheckBox}}" TargetType="{x:Type CheckBox}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="LogOptionButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>
    <Grid x:Name="mainGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox
            Name="MainTextBox"
            VerticalContentAlignment="Top"
            Background="Transparent"
            BorderThickness="0"
            FontFamily="Consolas,Microsoft YaHei,微软雅黑"
            FontSize="15"
            Foreground="{DynamicResource AppDataReceivedBrush}"
            IsReadOnly="True"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            TextWrapping="Wrap" />
        <ScrollViewer Name="MainListScrollViewer" VerticalScrollBarVisibility="Auto">
            <ItemsControl
                Name="MainList"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                VirtualizingStackPanel.CacheLength="2,2"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RichTextBox
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas,Microsoft YaHei,微软雅黑"
                            FontSize="12"
                            IsReadOnly="True">
                            <FlowDocument>
                                <Paragraph Margin="0">
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding TimeText}" />
                                    <Run Foreground="{DynamicResource AppGlassMutedBrush}" Text="{Binding ArrowText}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding DataTextColor}"
                                        Text="{Binding DataText}" />
                                    <Run
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AppGlassTextBrush}"
                                        Text="{Binding RawTitle}" />
                                    <Run
                                        FontSize="15"
                                        Foreground="{Binding RawTextColor}"
                                        Text="{Binding RawText}" />
                                    <Run Foreground="{Binding HexTextColor}" Text="{Binding HexText}" />
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <WrapPanel
            Grid.Row="1"
            MinHeight="36"
            Margin="10,4,0,6"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <CheckBox
                Name="RTSCheckBox"
                Content="RTS"
                IsChecked="{Binding Rts}"
                Style="{StaticResource LogOptionCheckBoxStyle}" />
            <CheckBox
                Name="DTRCheckBox"
                Content="DTR"
                IsChecked="{Binding Dtr}"
                Style="{StaticResource LogOptionCheckBoxStyle}" />
            <CheckBox
                Name="HexSendCheckBox"
                Content="{DynamicResource HexSendMode}"
                IsChecked="{Binding hexSend}"
                Style="{StaticResource LogOptionCheckBoxStyle}" />
            <CheckBox
                Name="ExtraEnterCheckBox"
                Content="{DynamicResource AddExtraEnter}"
                IsChecked="{Binding extraEnter}"
                Style="{StaticResource LogOptionCheckBoxStyle}"
                ToolTip="{DynamicResource AddExtraEnterTip}" />
            <CheckBox
                Name="EnterSendCheckBox"
                Content="{DynamicResource EnterSendMode}"
                IsChecked="{Binding enterSend}"
                Style="{StaticResource LogOptionCheckBoxStyle}"
                ToolTip="{DynamicResource EnterSendModeTip}" />
            <CheckBox
                Name="EnableSymbolCheckBox"
                Content="{DynamicResource ShowSymbol}"
                IsChecked="{Binding EnableSymbol}"
                Style="{StaticResource LogOptionCheckBoxStyle}"
                ToolTip="{DynamicResource ShowSymbolTooltip}" />
            <CheckBox
                Name="DisableLogCheckBox"
                Content="{DynamicResource DisableLog}"
                IsChecked="{Binding DisableLog}"
                Style="{StaticResource LogOptionCheckBoxStyle}" />
            <CheckBox
                Name="SessionLogCheckBox"
                Content="{DynamicResource SessionLog}"
                IsChecked="{Binding sessionLogEnabled}"
                Style="{StaticResource LogOptionCheckBoxStyle}"
                ToolTip="{DynamicResource SessionLogTip}" />
            <Button
                Name="SessionLogFolderButton"
                Click="SessionLogFolderButton_Click"
                Content="{DynamicResource SessionLogFolder}"
                Style="{StaticResource LogOptionButtonStyle}"
                ToolTip="{DynamicResource SessionLogFolderTip}" />
        </WrapPanel>
        <Button
            Name="LockLogButton"
            Margin="0,0,18,25"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="LockLogButton_Click"
            ToolTip="{DynamicResource LockLogButton}"
            Visibility="{Binding Path=IsMouseOver, ElementName=mainGrid, Converter={StaticResource boolVisibeConverter}}">
            <StackPanel>
                <fa:FontAwesome
                    Name="LockIcon"
                    Icon="Lock"
                    FontSize="16"
                    Height="12"
                    Visibility="{Binding LockLog, Converter={StaticResource boolNotVisibeConverter}}" />
                <fa:FontAwesome
                    Name="UnLockIcon"
                    Foreground="Green"
                    Icon="Unlock"
                    FontSize="16"
                    Height="12"
                    Visibility="{Binding LockLog, Converter={StaticResource boolVisibeConverter}}" />
                <TextBlock
                    Name="UnLockText"
                    Text="{DynamicResource LockLogText}"
                    Visibility="{Binding LockLog, Converter={StaticResource boolVisibeConverter}}" />
            </StackPanel>
        </Button>
        <Button
            Name="SaveLogButton"
            Margin="0,0,18,3"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="SaveLogButton_Click"
            ToolTip="{DynamicResource SaveLogButton}"
            Visibility="{Binding Path=IsMouseOver, ElementName=mainGrid, Converter={StaticResource boolVisibeConverter}}"
            BorderBrush="{StaticResource AppGlassBorderBrush}">
            <fa:FontAwesome Icon="Save" HorizontalAlignment="Center" FontSize="12"/>
        </Button>
    </Grid>
</Page>
