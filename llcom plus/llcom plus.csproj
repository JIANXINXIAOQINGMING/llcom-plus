  <ItemGroup>
    <Compile Include="$(IntermediateOutputPath)AppVersion.g.cs" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Target Name="LoadAppVersionFromProps" BeforeTargets="GenerateAppVersionInfo;SyncRepositoryVersionFiles;CreateReleaseZip">
    <XmlPeek
      XmlInputPath="$(MSBuildProjectDirectory)\..\Version.props"
      Query="/msb:Project/msb:PropertyGroup/msb:AppVersion/text()"
      Namespaces="&lt;Namespace Prefix='msb' Uri='http://schemas.microsoft.com/developer/msbuild/2003' /&gt;"
      Condition="Exists('$(MSBuildProjectDirectory)\..\Version.props')">
      <Output TaskParameter="Result" PropertyName="AppVersion" />
    </XmlPeek>
    <Error Condition="'$(AppVersion)' == ''" Text="AppVersion is empty. Check $(MSBuildProjectDirectory)\..\Version.props." />
    <Error Condition="'$(BinaryVersion)' == ''" Text="BinaryVersion is empty. Check $(MSBuildProjectDirectory)\..\Version.props." />
    <Error Condition="'$(AppxVersion)' == ''" Text="AppxVersion is empty. Check $(MSBuildProjectDirectory)\..\Version.props." />
    <Message Importance="High" Text="Version -> public $(AppVersion), binary $(BinaryVersion), appx $(AppxVersion)" />
  </Target>
  <Target Name="GenerateAppVersionInfo" BeforeTargets="CoreCompile">
    <ItemGroup>
      <AppVersionAssemblyAttribute Include="System.Reflection.AssemblyVersionAttribute">
        <_Parameter1>$(BinaryVersion)</_Parameter1>
      </AppVersionAssemblyAttribute>
      <AppVersionAssemblyAttribute Include="System.Reflection.AssemblyFileVersionAttribute">
        <_Parameter1>$(BinaryVersion)</_Parameter1>
      </AppVersionAssemblyAttribute>
      <AppVersionAssemblyAttribute Include="System.Reflection.AssemblyInformationalVersionAttribute">
        <_Parameter1>$(AppVersion)</_Parameter1>
      </AppVersionAssemblyAttribute>
    </ItemGroup>
    <WriteCodeFragment
      AssemblyAttributes="@(AppVersionAssemblyAttribute)"
      Language="C#"
      OutputFile="$(IntermediateOutputPath)AppVersion.g.cs" />
  </Target>
  <Target Name="SyncRepositoryVersionFiles" BeforeTargets="Build">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\..\build\Sync-Version.ps1&quot; -Root &quot;$(MSBuildProjectDirectory)\..&quot; -Version &quot;$(AppVersion)&quot; -AppxVersion &quot;$(AppxVersion)&quot; -AutoUpdate -AppxManifest" />
  </Target>
  <Target Name="ResolveNativeRuntimeFiles">
    <ItemGroup>
      <NativeRuntimeFile Include="$(MSBuildProjectDirectory)\Runtime\Native\x86\serial_monitor.dll" Condition="'$(PlatformTarget)' == 'x86' Or '$(Platform)' == 'x86'" />
      <NativeRuntimeFile Include="$(MSBuildProjectDirectory)\Runtime\Native\x64\serial_monitor.dll" Condition="'$(PlatformTarget)' == 'x64' Or '$(Platform)' == 'x64'" />
    </ItemGroup>
    <Error Condition="'@(NativeRuntimeFile)' == ''" Text="No native runtime files configured for PlatformTarget=$(PlatformTarget), Platform=$(Platform)." />
    <Error Condition="'@(NativeRuntimeFile)' != '' And !Exists('%(NativeRuntimeFile.Identity)')" Text="Missing native runtime file: %(NativeRuntimeFile.Identity)" />
  </Target>
  <Target Name="CopyNativeRuntimeFiles" AfterTargets="Build" DependsOnTargets="ResolveNativeRuntimeFiles">
    <Copy SourceFiles="@(NativeRuntimeFile)" DestinationFiles="@(NativeRuntimeFile->'$(TargetDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CopyOpenSslRuntimeFiles" AfterTargets="Build" Condition="Exists('$(MSBuildProjectDirectory)\Runtime\OpenSSL')">
    <ItemGroup>
      <OpenSslRuntimeFile Include="$(MSBuildProjectDirectory)\Runtime\OpenSSL\**\*" />
    </ItemGroup>
    <MakeDir Directories="$(TargetDir)OpenSSL" />
    <Copy SourceFiles="@(OpenSslRuntimeFile)" DestinationFiles="@(OpenSslRuntimeFile->'$(TargetDir)OpenSSL\%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CreateReleaseZip" AfterTargets="Build" DependsOnTargets="CopyNativeRuntimeFiles;CopyOpenSslRuntimeFiles" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <ReleasePackageVersion>$(AppVersion)</ReleasePackageVersion>
      <ReleasePackagePlatform>$(PlatformTarget)</ReleasePackagePlatform>
      <ReleasePackagePlatform Condition="'$(ReleasePackagePlatform)' == ''">$(Platform)</ReleasePackagePlatform>
      <ReleasePackageRoot>$(MSBuildProjectDirectory)\$(IntermediateOutputPath)release_package\$(AssemblyName)_$(ReleasePackageVersion)_$(ReleasePackagePlatform)</ReleasePackageRoot>
      <ReleasePackageZip>$(MSBuildProjectDirectory)\..\artifacts\release\$(AssemblyName)_$(ReleasePackageVersion)_$(ReleasePackagePlatform).zip</ReleasePackageZip>
    </PropertyGroup>
    <ItemGroup>
      <ReleasePackageFile Include="$(TargetDir)**\*" Exclude="$(TargetDir)**\*.pdb;$(TargetDir)**\*.xml;$(TargetDir)**\*.vshost.*;$(TargetDir)settings.json;$(TargetDir)settings.json.bakup;$(TargetDir)startup.log;$(TargetDir)logs\**\*;$(TargetDir)user_script_run\logs\**\*" />
      <OldReleasePackageZip Include="$(MSBuildProjectDirectory)\..\artifacts\release\$(AssemblyName)_*_$(ReleasePackagePlatform).zip" Exclude="$(ReleasePackageZip)" />
    </ItemGroup>
    <MakeDir Directories="$(MSBuildProjectDirectory)\..\artifacts\release" />
    <RemoveDir Directories="$(ReleasePackageRoot)" Condition="Exists('$(ReleasePackageRoot)')" />
    <MakeDir Directories="$(ReleasePackageRoot)" />
    <Copy SourceFiles="@(ReleasePackageFile)" DestinationFiles="@(ReleasePackageFile->'$(ReleasePackageRoot)\%(RecursiveDir)%(Filename)%(Extension)')" />
    <Delete Files="@(OldReleasePackageZip)" Condition="'@(OldReleasePackageZip)' != ''" />
    <Delete Files="$(ReleasePackageZip)" Condition="Exists('$(ReleasePackageZip)')" />
    <ZipDirectory SourceDirectory="$(ReleasePackageRoot)" DestinationFile="$(ReleasePackageZip)" />
    <Message Importance="High" Text="Release zip -> $(ReleasePackageZip)" />
  </Target>
